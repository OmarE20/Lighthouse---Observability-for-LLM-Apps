# Secrets -- never commit a real .env file.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Storage. Defaults to a local SQLite file at ~/.lighthouse/lighthouse.db
# if unset. Point this at Postgres in production, e.g.:
# LIGHTHOUSE_DATABASE_URL=postgresql://user:password@localhost:5432/lighthouse
LIGHTHOUSE_DATABASE_URL=sqlite:///./lighthouse.db

# CORS origins the FastAPI server will accept requests from (comma-separated).
LIGHTHOUSE_CORS_ORIGINS=http://localhost:5173
